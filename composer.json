{
    "name": "torresani/redirectanalytics",
    "description": "Tracks TYPO3 redirects via Google Analytics 4 Measurement Protocol (server-side)",
    "type": "typo3-cms-extension",
    "license": "GPL-2.0-or-later",
    "require": {
        "typo3/cms-core": "^13.0",
        "typo3/cms-redirects": "^13.0"
    },
    "autoload": {
        "psr-4": {
            "Torresani\\Redirectanalytics\\": "Classes/"
        }
    },
    "extra": {
        "typo3/cms": {
            "extension-key": "redirectanalytics"
        }
    }
}
